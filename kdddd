<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SAM ETF Dashboard</title>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>

<style>
body{
    background:#0b1020;
    color:white;
    font-family:sans-serif;
    margin:0;
    padding:40px;
}

.container{
    max-width:1200px;
    margin:auto;
}

h1{
    font-size:42px;
    margin-bottom:10px;
}

.sub{
    color:#94a3b8;
    margin-bottom:40px;
}

.card-grid{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:20px;
    margin-bottom:40px;
}

.card{
    background:#111827;
    border:1px solid #1e293b;
    border-radius:14px;
    padding:24px;
}

.label{
    color:#94a3b8;
    font-size:13px;
    margin-bottom:10px;
}

.value{
    font-size:32px;
    font-weight:700;
}

.chart-wrap{
    background:#111827;
    border:1px solid #1e293b;
    border-radius:14px;
    padding:24px;
}

canvas{
    margin-top:20px;
}
</style>
</head>

<body>

<div class="container">

    <h1>SAM ETF Dashboard</h1>

    <div class="sub">
        반도체 ETF 보유현황 분석 대시보드
    </div>

    <div class="card-grid">

        <div class="card">
            <div class="label">총 보유 평가액</div>
            <div class="value">1.25조</div>
        </div>

        <div class="card">
            <div class="label">총 보유 인원</div>
            <div class="value">175,120명</div>
        </div>

        <div class="card">
            <div class="label">평균 보유금액</div>
            <div class="value">714만원</div>
        </div>

    </div>

    <div class="chart-wrap">
        <h2>종목별 AUM</h2>
        <canvas id="myChart"></canvas>
    </div>

</div>

<script>

const ctx = document.getElementById('myChart');

new Chart(ctx, {
    type: 'bar',
    data: {
        labels: [
            'KODEX 반도체',
            'KODEX 레버리지',
            'KODEX AI반도체',
            'TIGER 반도체',
            'TIGER TOP10'
        ],
        datasets: [{
            label: 'AUM',
            data: [250,143,116,23,579]
        }]
    },
    options: {
        responsive: true
    }
});

</script>

</body>
</html>
